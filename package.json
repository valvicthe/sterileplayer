{
  "name": "quellqa-audio",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Quellqa: Cutest Audio Player with Deadly EQ",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "vite build && electron-builder"
  },
  "dependencies": {
    "jsmediatags": "^3.9.5",
    "lucide-react": "^0.300.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.quellqa.audio",
    "productName": "QuellqaAudio",
    "files": [
      "dist-web/**/*",
      "main.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
